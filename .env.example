# ============================================================
#  Configuración de Azure OpenAI para el Taller de Agentes de IA
#  1. Copia este archivo como  .env
#  2. Rellena los valores que te den los organizadores del taller
# ============================================================

# Endpoint de tu recurso de Azure OpenAI (termina en /)
AZURE_OPENAI_ENDPOINT=https://TU-RECURSO.openai.azure.com/

# Clave de la API (API key)
AZURE_OPENAI_API_KEY=pega-aqui-tu-clave

# Versión de la API de Azure OpenAI
AZURE_OPENAI_API_VERSION=2024-10-21

# Nombre del "deployment" (despliegue) del modelo de chat, p. ej. gpt-4o-mini
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Nombre del "deployment" del modelo de embeddings, p. ej. text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
