# ============================================================
#  Configuración de Azure AI Foundry para el Taller de Agentes de IA
#  1. Copia este archivo como  .env
#  2. Rellena los valores que te den los organizadores del taller
# ============================================================

# Clave de la API (la misma sirve para chat y embeddings en este recurso)
AZURE_API_KEY=pega-aqui-tu-clave

# --- Modelo de CHAT (LLM) · endpoint de inferencia de Azure AI Foundry ---
# El endpoint termina en /models
AZURE_CHAT_ENDPOINT=https://TU-RECURSO.services.ai.azure.com/models
# Nombre del modelo/deployment de chat, p. ej. Kimi-K2.5, gpt-4o-mini, etc.
AZURE_CHAT_MODEL=Kimi-K2.5
AZURE_CHAT_API_VERSION=2024-05-01-preview

# --- Modelo de EMBEDDINGS · endpoint de Azure OpenAI clásico ---
AZURE_EMBEDDING_ENDPOINT=https://TU-RECURSO.cognitiveservices.azure.com/
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_EMBEDDING_API_VERSION=2023-05-15
